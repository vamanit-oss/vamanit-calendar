<?xml version="1.0" encoding="utf-8"?>
<!--
    Android TV launcher banner — renders at 320×180 dp.
    Replace with tv_banner.png (320×180 px) for production.
    Per Android TV guidelines: landscape, no alpha.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark navy background -->
    <item>
        <shape>
            <solid android:color="#0D1117" />
        </shape>
    </item>
    <!-- Arch mark (centred) -->
    <item
        android:gravity="center"
        android:width="80dp"
        android:height="40dp"
        android:drawable="@drawable/vamanit_arch" />
</layer-list>
