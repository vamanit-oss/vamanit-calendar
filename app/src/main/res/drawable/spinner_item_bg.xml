<?xml version="1.0" encoding="utf-8"?>
<!-- Row background for calendar spinner items (both selected row and dropdown rows).
     Pressed/focused → light tan highlight; normal → transparent. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#E5E0D8" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#EEE9E0" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#EEE9E0" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F5F2EE" />
        </shape>
    </item>
</selector>
