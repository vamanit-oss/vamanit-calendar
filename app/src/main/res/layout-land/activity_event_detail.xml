<?xml version="1.0" encoding="utf-8"?>
<!--
    Event Detail — opened-notebook aesthetic
    LEFT PAGE:  white, back/source header, event title + colour bar,
                WHEN + ROOM sections, THINKcloud logo footer
    SPINE:      warm tan book-binding divider
    RIGHT PAGE: white, ATTENDEES + AGENDA sections
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#F0EDE6">

    <!-- ══════════════════════════════
         LEFT PAGE — Event identity
         ══════════════════════════════ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#FFFFFE"
        android:elevation="6dp">

        <!-- Top accent colour bar (per-calendar colour) -->
        <View
            android:id="@+id/view_color_bar"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:background="@color/accent" />

        <!-- Back + source + logo header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:tint="#1E293B"
                android:contentDescription="Back"
                android:focusable="true" />

            <TextView
                android:id="@+id/tv_source_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Google"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <!-- THINKcloud logo — top right of left page -->
            <ImageView
                android:id="@+id/iv_vamanit_logo"
                android:layout_width="100dp"
                android:layout_height="40dp"
                android:src="@drawable/thinkcloud_logo"
                android:contentDescription="THINKcloud"
                android:alpha="0.75"
                android:scaleType="fitEnd" />

        </LinearLayout>

        <!-- Faint ruling line -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#EEE9E0"
            android:layout_marginStart="24dp" android:layout_marginEnd="24dp"/>

        <!-- Scrollable left content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="24dp">

                <!-- Event title -->
                <TextView
                    android:id="@+id/tv_event_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Event Title"
                    android:textColor="#1E293B"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium"
                    android:lineSpacingMultiplier="1.15"
                    android:layout_marginBottom="4dp" />

                <!-- Calendar name -->
                <TextView
                    android:id="@+id/tv_calendar_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:layout_marginBottom="24dp" />

                <!-- Faint rule -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#EEE9E0" android:layout_marginBottom="20dp"/>

                <!-- WHEN -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WHEN"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tv_timing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="22dp"
                    android:text="Monday, 18 March · 10:00 – 11:00"
                    android:textColor="#2E75B6"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium" />

                <!-- ROOM -->
                <TextView
                    android:id="@+id/label_room"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ROOM"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tv_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="—"
                    android:textColor="#1E293B"
                    android:textSize="15sp" />

                <!-- Hidden views for right-page data passed via same layout -->
                <!-- Attendees and Agenda labels are on the RIGHT page below,
                     but we keep the IDs here so the Activity binding finds them -->

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Faint ruling line above logo footer -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#EEE9E0"
            android:layout_marginStart="24dp" android:layout_marginEnd="24dp"/>

        <!-- Notebook footer — page number feel -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event Details"
            android:textColor="#CBD5E1"
            android:textSize="11sp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="12dp" />

    </LinearLayout>

    <!-- ══════════════════════════════
         SPINE — book binding
         ══════════════════════════════ -->
    <LinearLayout
        android:layout_width="10dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#D1C9BB"
        android:elevation="8dp">

        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="#B8B0A2"
            android:layout_gravity="start" />

    </LinearLayout>

    <!-- ══════════════════════════════
         RIGHT PAGE — Details content
         ══════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#FFFFFE"
        android:elevation="2dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="32dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <!-- Faint ruling lines (notebook) -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#EEE9E0" android:layout_marginBottom="12dp"/>

            <!-- ATTENDEES -->
            <TextView
                android:id="@+id/label_attendees"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ATTENDEES"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_attendees"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:text="—"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.6" />

            <!-- Faint ruling line -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#EEE9E0" android:layout_marginBottom="20dp"/>

            <!-- AGENDA -->
            <TextView
                android:id="@+id/label_agenda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AGENDA"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="—"
                android:textColor="#334155"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.6" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
