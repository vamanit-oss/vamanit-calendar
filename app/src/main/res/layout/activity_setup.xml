<?xml version="1.0" encoding="utf-8"?>
<!--
    Setup Wizard — notebook aesthetic, matches sign-in + agenda screens.
    Scrollable page shown on first launch so the user can enter OAuth secrets
    and review the cloud console configuration steps.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFE">

    <!-- Top accent bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@color/accent" />

    <!-- Sticky header: logo + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#FFFFFE"
        android:elevation="2dp">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="36dp"
            android:src="@drawable/thinkcloud_logo"
            android:contentDescription="@null"
            android:scaleType="fitStart" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setup Wizard"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

    </LinearLayout>

    <!-- Ruling line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEE9E0" />

    <!-- ── Scrollable body ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Intro text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Before signing in, register the Client IDs below in your cloud consoles and paste the secrets here."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingExtra="3dp" />

            <!-- ════════════════════════════════════════════════════════════
                 SECTION 1 — Google Cloud Console
                 ════════════════════════════════════════════════════════════ -->

            <!-- Section heading -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="20dp"
                    android:background="#4285F4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  Step 1 · Google Cloud Console"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Ruling line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEE9E0"
                android:layout_marginTop="8dp" />

            <!-- Google instructions -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:text="1. Open console.cloud.google.com and select your project.\n2. APIs &amp; Services → Library → enable Google Calendar API.\n3. OAuth consent screen → add scopes: calendar.readonly, openid, email, profile.\n4. Credentials → Create OAuth client ID:\n    • Type: Desktop app  →  name it &quot;THINKcloud Phone&quot;\n    • Download the secret and paste it below.\n5. Create a second OAuth client ID:\n    • Type: TVs and Limited Input devices  →  name it &quot;THINKcloud TV&quot;\n    • Download the secret and paste it below.\n6. In the Desktop client settings confirm the redirect URI is:\n    com.googleusercontent.apps.{client-id}:/oauth2redirect" />

            <!-- ── Phone Client ID ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Phone (Desktop) Client ID"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:background="#F1F5F9"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/tv_phone_client_id_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true" />

                <ImageButton
                    android:id="@+id/btn_copy_phone_client_id"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_share"
                    android:contentDescription="Copy Phone Client ID"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/accent" />

            </LinearLayout>

            <!-- ── TV Client ID ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="TV (Limited Input) Client ID"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:background="#F1F5F9"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/tv_tv_client_id_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true" />

                <ImageButton
                    android:id="@+id/btn_copy_tv_client_id"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_share"
                    android:contentDescription="Copy TV Client ID"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/accent" />

            </LinearLayout>

            <!-- ── "Already configured" banner — shown when build-time secrets present ── -->
            <LinearLayout
                android:id="@+id/layout_build_secrets_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:background="#F0FDF4"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ "
                    android:textColor="#16A34A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Google client secrets are already configured in this build. No manual entry needed."
                    android:textColor="#15803D"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <!-- ── Secret inputs (hidden when build-time secrets are present) ── -->
            <LinearLayout
                android:id="@+id/layout_secret_entry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Phone Client Secret  *"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_phone_secret"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="GOCSPX-…"
                        android:inputType="textVisiblePassword"
                        android:fontFamily="monospace"
                        android:textSize="14sp"
                        android:imeOptions="actionNext"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="TV Client Secret  *"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_tv_secret"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="GOCSPX-…"
                        android:inputType="textVisiblePassword"
                        android:fontFamily="monospace"
                        android:textSize="14sp"
                        android:imeOptions="actionDone"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- ════════════════════════════════════════════════════════════
                 SECTION 2 — Microsoft Azure Portal
                 ════════════════════════════════════════════════════════════ -->

            <!-- Section heading -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="36dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="20dp"
                    android:background="#0078D4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  Step 2 · Microsoft Azure Portal"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Ruling line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEE9E0"
                android:layout_marginTop="8dp" />

            <!-- Microsoft instructions -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:text="1. Go to portal.azure.com → Microsoft Entra ID → App registrations.\n2. Find your existing registration or create a new one.\n   • Supported account types: Accounts in any organizational directory\n     and personal Microsoft accounts.\n3. Authentication → Add a platform → Mobile and desktop apps.\n   Paste the Redirect URI shown below.\n4. API permissions → Add a permission → Microsoft Graph → Delegated:\n   • Calendars.Read\n   • User.Read\n   • offline_access  (for background refresh)\n5. No client secret needed — MSAL uses a public client flow on Android." />

            <!-- No-secret note -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:background="#EFF6FF"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ "
                    android:textColor="#0078D4"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Microsoft does not require a client secret for mobile apps. No input needed here."
                    android:textColor="#0078D4"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <!-- ── Microsoft Client ID ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Microsoft Application (Client) ID"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:background="#F1F5F9"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/tv_ms_client_id_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true" />

                <ImageButton
                    android:id="@+id/btn_copy_ms_client_id"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_share"
                    android:contentDescription="Copy Microsoft Client ID"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#0078D4" />

            </LinearLayout>

            <!-- ── Microsoft Redirect URI ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Redirect URI  (add this in Azure → Authentication)"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:background="#F1F5F9"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/tv_ms_redirect_uri_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true" />

                <ImageButton
                    android:id="@+id/btn_copy_ms_redirect"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_share"
                    android:contentDescription="Copy Microsoft Redirect URI"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#0078D4" />

            </LinearLayout>

            <!-- ════════════════════════════════════════════════════════════
                 Email setup instructions
                 ════════════════════════════════════════════════════════════ -->

            <!-- Ruling line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEE9E0"
                android:layout_marginTop="36dp" />

            <!-- Section heading -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="20dp"
                    android:background="@color/accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  Email Setup Instructions"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Not sure what to enter above? Email yourself full step-by-step instructions for configuring Google Cloud Console and Azure Portal, including all Client IDs and redirect URIs."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:lineSpacingExtra="3dp" />

            <!-- Email address row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="your@email.com"
                        android:inputType="textEmailAddress"
                        android:textSize="14sp"
                        android:imeOptions="actionSend"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btn_email_instructions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Send"
                    android:textSize="13sp"
                    android:backgroundTint="@color/accent" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Leave blank to open your email app and choose the recipient yourself."
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontStyle="italic" />

            <!-- ════════════════════════════════════════════════════════════
                 Bottom action buttons
                 ════════════════════════════════════════════════════════════ -->

            <!-- Ruling line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEE9E0"
                android:layout_marginTop="28dp" />

            <Button
                android:id="@+id/btn_continue"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="Save Secrets &amp; Continue"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/accent" />

            <TextView
                android:id="@+id/btn_skip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:text="Skip — use secrets from build config"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="10dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
