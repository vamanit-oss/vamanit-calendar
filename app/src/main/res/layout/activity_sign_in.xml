<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Vamanit Logo — centered top third -->
    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="280dp"
        android:layout_height="100dp"
        android:src="@drawable/vamanit_logo"
        android:contentDescription="Vamanit logo"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_tagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.3" />

    <TextView
        android:id="@+id/tv_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sign_in_tagline"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/iv_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Sign-in buttons — large for TV D-pad and phone touch -->
    <Button
        android:id="@+id/btn_google_sign_in"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:text="@string/sign_in_google"
        android:textSize="16sp"
        android:focusable="true"
        android:nextFocusDown="@id/btn_microsoft_sign_in"
        android:backgroundTint="@color/google_blue"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/tv_tagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_microsoft_sign_in"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:text="@string/sign_in_microsoft"
        android:textSize="16sp"
        android:focusable="true"
        android:nextFocusUp="@id/btn_google_sign_in"
        android:backgroundTint="@color/microsoft_blue"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btn_google_sign_in"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_license"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/license_note"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:gravity="center"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
