<?xml version="1.0" encoding="utf-8"?>
<!--
    TV Dashboard — Opened-notebook layout
    LEFT PAGE:  white, large clock + date + logo
    SPINE:      4dp shadow divider (book binding)
    RIGHT PAGE: white, next meeting prominent + upcoming list
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#F0EDE6"
    android:keepScreenOn="true">

    <!-- ══════════════════════════════
         LEFT PAGE — Clock
         ══════════════════════════════ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#FFFFFE"
        android:gravity="center_horizontal"
        android:paddingStart="48dp"
        android:paddingEnd="40dp"
        android:paddingTop="28dp"
        android:paddingBottom="28dp"
        android:elevation="6dp">

        <!-- Logo row — top -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="90dp"
                android:layout_height="36dp"
                android:src="@drawable/thinkcloud_logo"
                android:contentDescription="@null"
                android:scaleType="fitStart" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="vamanit®"
                android:textColor="#9CA3AF"
                android:textSize="15sp"
                android:fontFamily="serif"
                android:letterSpacing="0.04" />

        </LinearLayout>

        <!-- Faint ruling lines (notebook paper effect) -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#EEE9E0" android:layout_marginTop="20dp"/>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#EEE9E0" android:layout_marginTop="18dp"/>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#EEE9E0" android:layout_marginTop="18dp"/>

        <!-- Flex spacer -->
        <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <!-- ── CLOCK ── -->
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#1E293B"
            android:textSize="112sp"
            android:fontFamily="sans-serif-thin"
            android:letterSpacing="-0.03"
            android:includeFontPadding="false" />

        <!-- Accent rule -->
        <View
            android:layout_width="64dp"
            android:layout_height="3dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="10dp"
            android:background="#2E75B6" />

        <!-- Date -->
        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monday, 1 January 2025"
            android:textColor="#94A3B8"
            android:textSize="17sp"
            android:fontFamily="sans-serif" />

        <!-- Flex spacer -->
        <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <!-- Faint ruling lines (bottom) -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#EEE9E0" android:layout_marginBottom="18dp"/>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#EEE9E0" android:layout_marginBottom="18dp"/>

        <!-- Calendar source badges — bottom -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_google_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Google"
                android:textColor="#4285F4"
                android:textSize="13sp"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/tv_ms_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Microsoft"
                android:textColor="#00A4EF"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════
         SPINE — book binding effect
         ══════════════════════════════ -->
    <LinearLayout
        android:layout_width="10dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#D1C9BB"
        android:elevation="8dp">

        <!-- Inner shadow on left edge -->
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="#B8B0A2"
            android:layout_gravity="start" />

    </LinearLayout>

    <!-- ══════════════════════════════
         RIGHT PAGE — Meetings
         ══════════════════════════════ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#FFFFFE"
        android:paddingStart="32dp"
        android:paddingEnd="40dp"
        android:paddingTop="28dp"
        android:paddingBottom="28dp"
        android:elevation="2dp">

        <!-- Page header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="UPCOMING MEETINGS"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12" />

            <TextView
                android:id="@+id/tv_event_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CBD5E1"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- ── NEXT MEETING — prominent card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_next_meeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:visibility="gone"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Top colour accent bar -->
                <View
                    android:id="@+id/view_next_color_bar"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:background="#2E75B6" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="14dp">

                    <!-- "NEXT" badge + source -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  NEXT  "
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1"
                            android:background="#2E75B6"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp" />

                        <TextView
                            android:id="@+id/tv_next_source"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Microsoft"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08" />

                    </LinearLayout>

                    <!-- Meeting title -->
                    <TextView
                        android:id="@+id/tv_next_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Meeting Title"
                        android:textColor="#1E293B"
                        android:textSize="21sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:layout_marginBottom="5dp" />

                    <!-- Time -->
                    <TextView
                        android:id="@+id/tv_next_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="09:00 – 10:00"
                        android:textColor="#2E75B6"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Location -->
                    <TextView
                        android:id="@+id/tv_next_location"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text=""
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- "ALSO TODAY" sub-label -->
        <TextView
            android:id="@+id/tv_also_today"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALSO TODAY"
            android:textColor="#CBD5E1"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Remaining events -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_events"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:focusable="true"
            android:descendantFocusability="afterDescendants"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <!-- Empty state -->
        <TextView
            android:id="@+id/tv_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/no_events"
            android:textColor="#CBD5E1"
            android:textSize="16sp"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
