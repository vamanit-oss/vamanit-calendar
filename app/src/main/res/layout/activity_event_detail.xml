<?xml version="1.0" encoding="utf-8"?>
<!--
    Event Detail — phone portrait single-column, notebook aesthetic
    White background, ruling lines, blue accent colour bar, clean typography
    (Landscape / TV uses layout-land/activity_event_detail.xml — split layout)
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFE"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top accent colour bar -->
        <View
            android:id="@+id/view_color_bar"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:background="@color/accent" />

        <!-- Header: back + source + logo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:tint="#1E293B"
                android:contentDescription="Back"
                android:focusable="true" />

            <TextView
                android:id="@+id/tv_source_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Google"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <ImageView
                android:id="@+id/iv_vamanit_logo"
                android:layout_width="100dp"
                android:layout_height="38dp"
                android:src="@drawable/thinkcloud_logo"
                android:contentDescription="THINKcloud"
                android:alpha="0.75"
                android:scaleType="fitEnd" />

        </LinearLayout>

        <!-- Ruling line -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#EEE9E0"
            android:layout_marginStart="24dp" android:layout_marginEnd="24dp"/>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- Event title -->
            <TextView
                android:id="@+id/tv_event_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Event Title"
                android:textColor="#1E293B"
                android:textSize="26sp"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingMultiplier="1.15"
                android:layout_marginBottom="4dp" />

            <!-- Calendar name -->
            <TextView
                android:id="@+id/tv_calendar_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:layout_marginBottom="20dp" />

            <!-- Ruling line -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#EEE9E0" android:layout_marginBottom="18dp"/>

            <!-- WHEN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WHEN"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_timing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="20dp"
                android:text="Monday, 18 March · 10:00 – 11:00"
                android:textColor="#2E75B6"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <!-- ROOM -->
            <TextView
                android:id="@+id/label_room"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROOM"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="20dp"
                android:text="—"
                android:textColor="#1E293B"
                android:textSize="15sp" />

            <!-- Ruling line -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#EEE9E0" android:layout_marginBottom="18dp"/>

            <!-- ATTENDEES -->
            <TextView
                android:id="@+id/label_attendees"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ATTENDEES"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_attendees"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="20dp"
                android:text="—"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.6" />

            <!-- Ruling line -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#EEE9E0" android:layout_marginBottom="18dp"/>

            <!-- AGENDA -->
            <TextView
                android:id="@+id/label_agenda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AGENDA"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="—"
                android:textColor="#334155"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.6" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
